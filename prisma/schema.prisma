generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Hotel{
  id                    String   @id @default(uuid())
  offerTitle            String   
  hotelName             String 
  hotelAddress          String 
  phoneNumber           String 
  contactEmail          String 
  hotelDescription      String 
  hotelImageUrl         String 
  stars                 Int   
  currency              String
  price                 Float
  discount              Float?
  marketType            String?
  recommended           Boolean? 
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  // minPricePerNight      Float //
  // maxPricePerNight      Float  both are not used in the new design
}

enum PackageType {
  VACATION
  OMRA
  HADJ
}

model Package {
  id                String      @id @default(uuid())
  userId            String
  isPublic          Boolean     @default(false)
  combination_active Boolean     @default(false)
  isRecommended Boolean     @default(false)
  name              String
  displayName       String
  option           Float
  priority         Int
  departureCity    String
  type             PackageType @default(VACATION)
  shortDescription String
  description      String?
  importantNotes  String?
  empContract String?
  inclusion      String?
  primaryImageUrl String?

  min_age_first_child Int?
  max_age_first_child Int?
  min_age_second_child Int?
  max_age_second_child Int?

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  departures      Departure[]
  destinations    Destination[]
  pricePerPerson  PricePerPerson? 

  secondaryImages  PackageImage[]
  slots DepartureSlot[]
  conditions ConditionAnnulation[]
  steps PackageStep[]
  packageCombinations PackageCombination[]
  packageSupplements PackageSupplements[]
}

enum PackagePensionType {
  ROOM_ONLY
  BED_AND_BREAKFAST
  HALF_BOARD
  FULL_BOARD
  ALL_INCLUSIVE
}

model PackageCombination {
  id                String   @id @default(uuid())
  packageId         String

  package           Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  combination      Combination[]
}

model Combination {
  id                String   @id @default(uuid())
  packageCombinationId String
  name              String
  pension           PackagePensionType @default(ROOM_ONLY)
  price             Float
  majoration        Float
  adultsNumber      Int
  numbOfChildrenOne   Int
  numbOfChildrenTwo   Int
  babyPrice         Float

  packageCombination PackageCombination @relation(fields: [packageCombinationId], references: [id], onDelete: Cascade)
}

model PackageSupplements {
  id                String   @id @default(uuid())
  packageId         String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  package           Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)
  supplements       Supplements[]
}

model Supplements {
  id                String   @id @default(uuid())
  packageSupplementsId String
  name              String
  adultsNumber      Int
  numbOfChildrenOne   Int
  numbOfChildrenTwo   Int
  babyPrice         Float
  packageSupplements PackageSupplements @relation(fields: [packageSupplementsId], references: [id], onDelete: Cascade)
}

enum PackageStepType {
  HOTEL
  VOL
  TRANSFER
  EXCURSION
}

model PackageStep {
  id                String   @id @default(uuid())
  packageId         String
  type             PackageStepType @default(HOTEL)
  hotelName         String
  nights            Int
  rate    Int  
  description      String
  address String
  primaryImageUrl   String
  package           Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  secondaryImages  PackageStepSecondaryImages[]
}

model PackageStepSecondaryImages {
  id                String   @id @default(uuid())
  packageStepId     String
  imageUrl          String
  packageStep       PackageStep @relation(fields: [packageStepId], references: [id], onDelete: Cascade)
}

model ConditionAnnulation {
  id                String   @id @default(uuid())
  de DateTime
  arrival DateTime
  packageId         String
  package          Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)
}

model DepartureSlot {
  id                String   @id @default(uuid())
  packageId         String
  start DateTime
  finish DateTime
  days Int
  nights Int
  initialPlace Int
  package           Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)
}

model PackageImage {
  id                String   @id @default(uuid())
  packageId         String   @unique
  url               String   
  package           Package  @relation(fields: [packageId], references: [id])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Departure {
  id                String   @id @default(uuid())
  packageId         String
  name             String
  package          Package @relation(fields: [packageId], references: [id], onDelete: Cascade)
}

model Destination {
  id                String   @id @default(uuid())
  packageId         String
  name             String
  package          Package @relation(fields: [packageId], references: [id], onDelete: Cascade)
}

model PricePerPerson {
  id                String   @id @default(uuid())
  packageId      String           @unique
  markupPlatform Float
  markupAgency   Float
  package          Package @relation(fields: [packageId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  prices          Price[]
}

model Price {
  id                String   @id @default(uuid())
  pricePerPersonId String
  name            String
  adultPrice      Float
  childPrice6To11      Float
  childPrice2To5      Float
  infantPrice      Float
  pricePerPerson  PricePerPerson @relation(fields: [pricePerPersonId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model User {
  id           String      @id @default(uuid())
  firstName    String
  lastName     String
  username     String      @unique
  email        String      @unique
  password     String
  roleId       String
  phoneNumber  String
  address      String?
  userActive   Boolean     @default(false)
  adminActive  Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  connection_from_outside Boolean @default(false)

  agencyInfo   AgencyInfos? @relation(fields: [agency], references: [id])
  agency       String?      // FK to AgencyInfos.id

  role         Role     @relation(fields: [roleId], references: [id])
  packages  Package[]
}

model AgencyInfos {
  id                      String        @id @default(uuid())
  agencyName              String        
  RIZCode                 String
  email                   String
  website                 String?
  agencyAddress           String?
  phoneNum1               String?
  phoneNum2               String?
  phoneNum3               String?
  MFAType                 String?
  activated               Boolean?      @default(false)
  isCompany               Boolean?      @default(false)
  useTravelersProfiles    Boolean?      @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  // Relations 
  logo                    Logo[]
  users                   User[]
  accounting              Accounting?
  authoration             Authoration?
  products                Products?
  b2c                     B2C?
}

model Logo {
  id         String   @id @default(uuid())
  agencyId   String
  logoPath   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // relations
  agencyInfos   AgencyInfos  @relation(fields: [agencyId], references: [id], onDelete: Cascade)
}

model Accounting {
  id                                     String       @id @default(uuid())
  agencyCommissionLowCoTick              Float   
  hideEtickectPrice                      Boolean     @default(false)
  hideHotelVoucherPrice                  Boolean     @default(false)
  hideCancellationPoliciesOnHotelVoucher Boolean     @default(false)

  agencyId                               String       @unique
  agencyInfos                            AgencyInfos  @relation(fields: [agencyId], references: [id], onDelete: Cascade)
}

model Authoration {
  id                                  String       @id @default(uuid())
  localAutherizedOverdraw             Float
  confirmBooking                      Boolean      @default(false)
  GDSBookWithoutBalance               Boolean      @default(false)
  foreignCurrencycCertAuthorization   Boolean      @default(false)

  agencyId                            String       @unique
  agencyInfos                         AgencyInfos  @relation(fields: [agencyId], references: [id], onDelete: Cascade)
}

model Products {
  id                String       @id @default(uuid())
  flightBooking     Boolean      @default(false)
  hotelBooking      Boolean      @default(false)
  package           Boolean      @default(false)
  visa              Boolean      @default(false)

  agencyId          String       @unique
  agencyInfos       AgencyInfos  @relation(fields: [agencyId], references: [id], onDelete: Cascade)
}

model B2C {
  id             String       @id @default(uuid())
  country        String
  department     String
  city           String
  latitude       Float?
  longitude      Float?
  B2CpointOfSale Boolean      @default(false)

  agencyId  String            @unique
  agencyInfos    AgencyInfos  @relation(fields: [agencyId], references: [id], onDelete: Cascade)
}


model Role {
  id         String    @id @default(uuid())
  name       String    @unique
  isDefault  Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime? // For soft delete

  permissions RolePermissions[]
  users       User[] // renamed for clarity

}

model Permission {
  id         String   @id @default(uuid())
  resource   String
  action     String
  identifier String   @unique // e.g., "vessel:read"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  roles RolePermissions[]
}

model RolePermissions {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String

  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId]) // prevent duplicates
}


 // VISA Section

model Country {
  id              String   @id @default(uuid())
  name            String   @unique
  flagUrl         String
  visa           Visa[]
}

model Visa {
  id           String @id @default(uuid())
  countryId    String
  name         String 
  price        Float
  currency     String
  description  String
  conditions   String
  status       Boolean     @default(true)
  duration     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime? 

  // relations
  visaRequest  VisaRequestPivot[]
  country      Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)

  // index
  @@index([countryId], name: "visa_countryId_idx")
}

model VisaRequestPivot {
  id String @id @default(uuid())
  visaId String
  visaRequestId String
  createdAt DateTime @default(now())

  // relations
  visa Visa @relation(fields: [visaId], references: [id], onDelete: Cascade)
  visaRequest VisaRequest @relation(fields: [visaRequestId], references: [id], onDelete: Cascade)
}

model VisaRequest {
  id String @id @default(uuid())
  agentName String
  agencyName String
  travelStartingDate DateTime
  groupSize Int
  nationality String
  totalPrice String  // total price for all passengers
  status String @default("Pending") // pending, in_progress, completed, rejected
  notes String?
  startedAt DateTime?
  confirmedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  // relations
  viseRequestPivot VisaRequestPivot[]
  // visaRequestDocuments VisaRequestDocuments[]
  passengers Passenger[]
}

