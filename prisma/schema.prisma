// Passenger Section

model Passenger {
  id String @id @default(uuid())
  visaRequestId String
  name String
  surname String
  placeOfBirth String
  dateOfBirth DateTime
  passportNumber String
  passportDeliveryDate DateTime
  passportExpirationDate DateTime
  email String
  phone String
  notes String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  // relations
  visaRequest VisaRequest @relation(fields: [visaRequestId], references: [id], onDelete: Cascade)
  passengerDocuments PassengerDocuments[]
}

model PassengerDocuments {
  id String @id @default(uuid())
  passengerId String
  documentId String
  label String?  @default("Document")
  isMendatory Boolean? @default(true)
  createdAt DateTime @default(now())

  // relations
  passenger Passenger @relation(fields: [passengerId], references: [id], onDelete: Cascade)
  passengerDocumentsFiles PassengerDocumentsFiles @relation(fields: [documentId], references: [id], onDelete: Cascade)
  
  @@unique([passengerId, documentId]) // prevent duplicates
}

model PassengerDocumentsFiles {
  id String @id @default(uuid())
  filePath String
  fileType String
  name String
  uploadedAt DateTime @default(now())
  deletedAt DateTime  @updatedAt

  // relations
  passengerDocuments PassengerDocuments[]
}


// Service Fees 

model ServiceFees{
  id            String @id @default(uuid())
  tourcodeTitle String
  description   String?
  GDSProvider   String

  itinerary Itinerary[]
  accounting ServiceFeesAccounting[]
}

model Itinerary {
  id String @id @default(uuid())
  tourcodeCompany String
  type        String?
  itinerary  String
  classes    String
  bookingFrom String 
  bookingTo String
  departureFrom String
  departureTo   String
  active    Boolean @default(false)

  serviceFeesId String
  serviceFees ServiceFees @relation(fields: [serviceFeesId], references: [id], onDelete: Cascade)
}

model ServiceFeesAccounting {
  id String @id @default(uuid())
  fixedPrice  Float
  percentage  Float? @default(0)
  
  serviceFeesId String
  serviceFees ServiceFees @relation(fields: [serviceFeesId], references: [id], onDelete: Cascade)
}